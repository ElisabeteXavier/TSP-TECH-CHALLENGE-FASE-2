## Exemplo de variáveis de ambiente (NÃO coloque chaves reais no git)

# Provider do LLM (suportado: groq, openai)
LLM_PROVIDER=groq

# Groq (OpenAI-compatible)
GROQ_API_KEY=coloque_sua_chave_aqui
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI
OPENAI_API_KEY=coloque_sua_chave_aqui
OPENAI_MODEL=gpt-4o-minix

